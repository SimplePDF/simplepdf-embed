{
  "name": "@simplepdf/embed",
  "version": "0.1.0",
  "description": "Typed bridge for embedding and programmatically driving the SimplePDF editor",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SimplePDF/simplepdf-embed",
    "directory": "packages/embed"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "embed-api.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    },
    "./ai-sdk": {
      "types": "./dist/ai-sdk.d.ts",
      "import": "./dist/ai-sdk.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./unwrap": {
      "types": "./dist/unwrap.d.ts",
      "import": "./dist/unwrap.js"
    }
  },
  "scripts": {
    "generate": "node scripts/generate.mjs",
    "prebuild": "npm run generate",
    "build": "tsup",
    "prepare": "npm run build",
    "pretest:types": "npm run generate",
    "test:types": "tsc --noEmit",
    "pretest": "npm run generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:size": "npm run build && node scripts/check-bundle-size.mjs"
  },
  "peerDependencies": {
    "ai": ">=4",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "ai": "^6.0.209",
    "jsdom": "^26.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17",
    "zod": "^4.4.3"
  }
}
