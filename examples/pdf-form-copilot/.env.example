# =============================================================================
# Access keys
# =============================================================================
#
# SHARED_API_KEYS is REQUIRED. There is no default / open / hybrid mode:
# requests without a valid ?share= return 401. Anyone who wants to run the
# demo without an invite link brings their own key via the Model Picker
# (BYOK is browser-direct and never hits this server).
#
# Shape: stringified JSON of share-id -> { api_key, rate_limit_turns_lifetime }.
#
#   {
#     "<share_id>": {
#       "api_key": "sk-ant-...",
#       "rate_limit_turns_lifetime": 20
#     }
#   }
#
# Each share id gets its own per-IP lifetime counter (reset only on server
# restart; optionally persisted to S3 via the vars below). The reserved id
# "__default__" is rejected at parse time. Example with two invites:
#
#   SHARED_API_KEYS='{"preview-alice":{"api_key":"sk-ant-...","rate_limit_turns_lifetime":5},"customer-acme":{"api_key":"sk-ant-...","rate_limit_turns_lifetime":100}}'
SHARED_API_KEYS=

# =============================================================================
# Client configuration
# =============================================================================

# SimplePDF company identifier: the subdomain piece of
# <companyIdentifier>.<base domain> that serves the embedded editor.
# Exposed to the browser (VITE_ prefix) because the iframe src is built
# client-side. Default: form-copilot.
VITE_SIMPLEPDF_COMPANY_IDENTIFIER=form-copilot

# Optional. Base URL of the SimplePDF marketing / editor host. Accepts a
# full URL (protocol + host + optional port); the company identifier above
# is spliced in as a subdomain when the iframe src is built. Use this to
# point the example at a local dev checkout instead of production.
# Default when unset: https://simplepdf.com
VITE_SIMPLEPDF_BASE_DOMAIN=https://self-hosted-domain

# Optional. Gates the TanStack Router + devtools panel. Leave unset in
# production / CI; set to "true" for local dev.
# VITE_ENABLE_DEVTOOLS=true

# =============================================================================
# Rate-limit persistence (optional; all seven must be set together)
# =============================================================================

# Salt the SHA-256 IP hash used for rate limiting. REQUIRED when the S3
# persistence vars below are set: without a salt, a leak of the persisted
# object would let anyone brute-force the IPv4 space in minutes. The server
# refuses to start if S3 persistence is configured and this is empty.
# IP_HASH_SALT=

# Persist the rate-limit state to S3 / DO Spaces so it survives restarts and
# deploys. All six S3 vars + IP_HASH_SALT must be present to enable it.
# S3_ENDPOINT=https://fra1.digitaloceanspaces.com
# S3_REGION=us-east-1
# S3_BUCKET=beautiful-space
# S3_RATE_LIMIT_KEY=simple-pdf/rate-limits/pdf-form-copilot.json
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
