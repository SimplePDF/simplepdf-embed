# Server-only. Never commit a real key.
ANTHROPIC_API_KEY=

# SimplePDF company identifier — the subdomain piece of
# <companyIdentifier>.simplepdf.com that serves the embedded editor.
# Exposed to the browser (VITE_ prefix) because the iframe src is built
# client-side. Default: pdf-form-copilot.
VITE_SIMPLEPDF_COMPANY_IDENTIFIER=pdf-form-copilot

# Optional: override the in-memory lifetime cap (per-IP, no reset).
# Useful for local development. Default: 75 fresh user turns per IP
# for the lifetime of the server process.
# RATE_LIMIT_LIFETIME=5000

# Optional: restrict /api/chat + /api/summarize to these Origins / Referers
# (comma-separated). Requests from anywhere else get a 403. Leave unset to
# allow everything (dev default).
# ALLOWED_ORIGINS=https://copilot.simplepdf.com,https://pdf-form-copilot.simplepdf.com

# Optional: persist the rate-limit state to S3 / DO Spaces so it survives
# restarts and deploys. All five variables must be present to enable it.
# S3_ENDPOINT=https://fra1.digitaloceanspaces.com
# S3_REGION=us-east-1
# S3_BUCKET=beautiful-space
# S3_RATE_LIMIT_KEY=simple-pdf/rate-limits/pdf-form-copilot.json
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
